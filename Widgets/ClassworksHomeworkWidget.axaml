<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="using:ClassworksPlugin.Models"
             xmlns:vm="using:ClassworksPlugin"
             x:Class="ClassworksPlugin.Widgets.ClassworksHomeworkWidget"
             x:DataType="vm:ClassworksHomeworkViewModel">
  <Border Padding="12" CornerRadius="12">
    <StackPanel Spacing="8">
      <TextBlock Text="Classworks 作业" FontSize="16" FontWeight="SemiBold" />
      <TextBlock Text="{Binding Status}" FontStyle="Italic" Opacity="0.75" />
      <ListBox ItemsSource="{Binding Assignments}" MinHeight="120">
        <ListBox.ItemTemplate>
          <DataTemplate DataType="models:Assignment">
            <Border Padding="8" Margin="0,0,0,4" CornerRadius="8">
              <StackPanel Spacing="4">
                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
                <TextBlock Text="{Binding Description}" TextWrapping="Wrap" Opacity="0.85" />
              </StackPanel>
            </Border>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
      <Grid ColumnDefinitions="*,*,Auto" ColumnSpacing="8">
        <TextBox Grid.Column="0" Watermark="科目" Text="{Binding NewTitle}" />
        <TextBox Grid.Column="1" Watermark="内容" Text="{Binding NewDescription}" />
        <Button Grid.Column="2" Content="添加" Click="OnAddClick" />
      </Grid>
      <Button Content="刷新" HorizontalAlignment="Left" Click="OnRefreshClick" />
    </StackPanel>
  </Border>
</UserControl>
