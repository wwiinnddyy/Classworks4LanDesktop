<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="using:ClassworksPlugin.Models"
             xmlns:vm="using:ClassworksPlugin"
             x:Class="ClassworksPlugin.Widgets.ClassworksHomeworkWidget"
             x:DataType="vm:ClassworksHomeworkViewModel">
  <Border Name="RootBorder"
          Padding="16"
          CornerRadius="12"
          BorderThickness="1">
    <StackPanel Spacing="12">
      <!-- Header -->
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel Grid.Column="0" Spacing="4">
          <TextBlock Text="Classworks 作业"
                     FontSize="18"
                     FontWeight="SemiBold" />
          <TextBlock Text="{Binding Status}"
                     FontSize="12"
                     Opacity="0.7" />
        </StackPanel>
        <Button Grid.Column="1"
                Content="🔄"
                Click="OnRefreshClick"
                Padding="8,4"
                IsEnabled="{Binding !IsLoading}"/>
      </Grid>

      <!-- Assignment List -->
      <Border Background="#10000000"
              CornerRadius="8"
              Padding="8"
              MinHeight="150">
        <ScrollViewer MaxHeight="300">
          <ItemsControl ItemsSource="{Binding Assignments}">
            <ItemsControl.ItemTemplate>
              <DataTemplate DataType="models:Assignment">
                <Border Padding="10"
                        Margin="0,0,0,8"
                        CornerRadius="6"
                        Background="#08000000"
                        BorderBrush="#20000000"
                        BorderThickness="1">
                  <StackPanel Spacing="6">
                    <TextBlock Text="{Binding Title}"
                               FontWeight="SemiBold"
                               FontSize="14"/>
                    <TextBlock Text="{Binding Description}"
                               TextWrapping="Wrap"
                               FontSize="12"
                               Opacity="0.85" />
                    <TextBlock Text="{Binding DueDate, StringFormat='截止：{0:MM/dd HH:mm}'}"
                               FontSize="11"
                               Opacity="0.7" />
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
      </Border>

      <!-- Add Assignment Form -->
      <Expander Header="➕ 添加新作业"
                IsExpanded="False">
        <StackPanel Spacing="8" Margin="0,8,0,0">
          <TextBox Watermark="科目名称（例如：数学）"
                   Text="{Binding NewTitle}"
                   MaxLength="50"/>
          <TextBox Watermark="作业内容（例如：完成习题册 P42-45）"
                   Text="{Binding NewDescription}"
                   AcceptsReturn="True"
                   TextWrapping="Wrap"
                   MinHeight="60"
                   MaxLength="500"/>
          <Button Content="添加作业"
                  Click="OnAddClick"
                  HorizontalAlignment="Right"
                  IsEnabled="{Binding !IsLoading}"/>
        </StackPanel>
      </Expander>
    </StackPanel>
  </Border>
</UserControl>
