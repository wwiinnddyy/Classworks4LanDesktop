<?xml version="1.0" encoding="utf-8"?>
<!--
  Settings page for the Classworks plugin.  This view uses FluentAvalonia
  controls to provide a modern look consistent with the host application.
  Users can choose to either enter their namespace/password/AppId directly
  or open a browser to obtain a token via OAuth.  Bindings refer to
  properties on ClassworksSettingsViewModel.
-->
<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fa="clr-namespace:FluentAvalonia.UI.Controls;assembly=FluentAvalonia"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:ClassworksPlugin.Views.Settings"
             x:Class="ClassworksPlugin.Views.Settings.ClassworksSettingsPage"
             mc:Ignorable="d">
  <StackPanel Spacing="12" Padding="16">
    <TextBlock Text="Classworks 设置" FontSize="20" FontWeight="Bold"/>
    <!-- 登录方式选择 -->
    <fa:RadioButtons SelectedIndex="{Binding LoginMethodIndex, Mode=TwoWay}">
      <fa:RadioButton Content="直接填写命名空间/密码/AppId"/>
      <fa:RadioButton Content="通过浏览器登录"/>
    </fa:RadioButtons>

    <!-- 直接填写方式 -->
    <StackPanel Spacing="8" IsVisible="{Binding IsDirectInputMode}" Margin="0,8,0,0">
      <StackPanel Orientation="Horizontal" Spacing="8">
        <TextBlock Text="命名空间:" VerticalAlignment="Center" Width="80"/>
        <fa:TextBox Width="200" Text="{Binding NamespaceId, Mode=TwoWay}"/>
      </StackPanel>
      <StackPanel Orientation="Horizontal" Spacing="8">
        <TextBlock Text="密码:" VerticalAlignment="Center" Width="80"/>
        <fa:PasswordBox Width="200" Password="{Binding Password, Mode=TwoWay}"/>
      </StackPanel>
      <StackPanel Orientation="Horizontal" Spacing="8">
        <TextBlock Text="App Id:" VerticalAlignment="Center" Width="80"/>
        <fa:TextBox Width="200" Text="{Binding AppId, Mode=TwoWay}"/>
      </StackPanel>
      <fa:Button Content="保存设置" Width="100" Margin="0,8,0,0" Click="OnSaveSettingsClick"/>
    </StackPanel>

    <!-- 浏览器登录方式 -->
    <StackPanel Spacing="8" IsVisible="{Binding IsBrowserMode}" Margin="0,8,0,0">
      <TextBlock TextWrapping="Wrap">
        该方式将打开默认浏览器，引导你完成 ZeroCat OAuth 登录并授权应用访问 Classworks 数据。
      </TextBlock>
      <fa:Button Content="通过浏览器登录" Width="160" Click="OnBrowserLoginClick"/>
      <TextBlock Text="登录完成后会自动更新插件状态" FontStyle="Italic" FontSize="12"/>
    </StackPanel>
  </StackPanel>
</UserControl>