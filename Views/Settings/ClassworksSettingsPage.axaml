<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ClassworksPlugin.ViewModels.Settings"
             x:Class="ClassworksPlugin.Views.Settings.ClassworksSettingsPage"
             x:DataType="vm:ClassworksSettingsViewModel">
  <ScrollViewer>
    <StackPanel Spacing="16" Margin="20" MaxWidth="600">
      <!-- Page Header -->
      <StackPanel Spacing="4">
        <TextBlock Text="{Binding PageTitle}"
                   FontSize="24"
                   FontWeight="Bold" />
        <TextBlock Text="配置 Classworks 云服务连接信息"
                   FontSize="14"
                   Opacity="0.7"/>
      </StackPanel>

      <!-- Connection Info Card -->
      <Border Background="#10000000"
              BorderBrush="#20000000"
              BorderThickness="1"
              CornerRadius="8"
              Padding="16">
        <StackPanel Spacing="12">
          <TextBlock Text="📡 连接信息"
                     FontSize="16"
                     FontWeight="SemiBold" />
          <TextBlock Text="连接 Classworks 使用的厚浪云 KV 命名空间。在 Classworks 网页端创建应用后可获得以下信息。"
                     TextWrapping="Wrap"
                     FontSize="13"
                     Opacity="0.8" />
        </StackPanel>
      </Border>

      <!-- Settings Form -->
      <StackPanel Spacing="12">
        <!-- Namespace ID -->
        <StackPanel Spacing="6">
          <TextBlock Text="命名空间 ID *" FontWeight="SemiBold" FontSize="13"/>
          <TextBox Text="{Binding NamespaceId}"
                   Watermark="例如：my-namespace"
                   MinHeight="36"/>
          <TextBlock Text="在厚浪云 KV 服务中创建的命名空间标识符"
                     FontSize="11"
                     Opacity="0.6"/>
        </StackPanel>

        <!-- Password -->
        <StackPanel Spacing="6">
          <TextBlock Text="访问密码 *" FontWeight="SemiBold" FontSize="13"/>
          <TextBox Text="{Binding Password}"
                   PasswordChar="●"
                   Watermark="输入访问密码"
                   MinHeight="36"/>
          <TextBlock Text="用于访问命名空间的密码"
                     FontSize="11"
                     Opacity="0.6"/>
        </StackPanel>

        <!-- App ID -->
        <StackPanel Spacing="6">
          <TextBlock Text="App ID *" FontWeight="SemiBold" FontSize="13"/>
          <TextBox Text="{Binding AppId}"
                   Watermark="例如：classworks-app-001"
                   MinHeight="36"/>
          <TextBlock Text="在 Classworks 网页端创建应用后获得的应用 ID"
                     FontSize="11"
                     Opacity="0.6"/>
        </StackPanel>

        <!-- KV Base URL -->
        <StackPanel Spacing="6">
          <TextBlock Text="KV 服务地址" FontWeight="SemiBold" FontSize="13"/>
          <TextBox Text="{Binding KvBaseUrl}"
                   Watermark="https://kv-service.wuyuan.dev"
                   MinHeight="36"/>
          <TextBlock Text="厚浪云 KV 服务的 API 地址，通常使用默认值即可"
                     FontSize="11"
                     Opacity="0.6"/>
        </StackPanel>
      </StackPanel>

      <!-- Action Buttons -->
      <StackPanel Spacing="10" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
        <Button Content="💾 保存设置"
                Click="OnSaveSettingsClick"
                Padding="16,8"
                HorizontalAlignment="Right" />
      </StackPanel>

      <!-- Help Section -->
      <Border Background="#08000000"
              BorderBrush="#15000000"
              BorderThickness="1"
              CornerRadius="8"
              Padding="16"
              Margin="0,8,0,0">
        <StackPanel Spacing="8">
          <TextBlock Text="💡 使用说明"
                     FontSize="14"
                     FontWeight="SemiBold" />
          <TextBlock TextWrapping="Wrap" FontSize="12" Opacity="0.8">
            <Run Text="1. 访问 Classworks 网页端创建应用，获取 App ID"/>
            <LineBreak/>
            <Run Text="2. 在厚浪云 KV 服务中创建命名空间，获取命名空间 ID 和密码"/>
            <LineBreak/>
            <Run Text="3. 填写以上信息并保存"/>
            <LineBreak/>
            <Run Text="4. 组件将自动同步今日作业数据"/>
          </TextBlock>
        </StackPanel>
      </Border>
    </StackPanel>
  </ScrollViewer>
</UserControl>
