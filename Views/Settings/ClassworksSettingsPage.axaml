<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ClassworksPlugin.ViewModels.Settings"
             x:Class="ClassworksPlugin.Views.Settings.ClassworksSettingsPage"
             x:DataType="vm:ClassworksSettingsViewModel">
  <StackPanel Spacing="12" Margin="16">
    <TextBlock Text="{Binding PageTitle}" FontSize="20" FontWeight="Bold" />
    <TextBlock Text="连接 Classworks 使用的厚浪云 KV 命名空间。在 Classworks 网页端创建应用后可获得 App ID。"
               TextWrapping="Wrap" Opacity="0.8" />
    <TextBox Watermark="命名空间" Text="{Binding NamespaceId}" />
    <TextBox Watermark="访问密码" Text="{Binding Password}" PasswordChar="*" />
    <TextBox Watermark="App ID" Text="{Binding AppId}" />
    <TextBox Watermark="KV 服务地址" Text="{Binding KvBaseUrl}" />
    <Button Content="保存设置" HorizontalAlignment="Left" Click="OnSaveSettingsClick" />
    <Button Content="通过浏览器登录（实验性）" HorizontalAlignment="Left" Click="OnBrowserLoginClick" />
  </StackPanel>
</UserControl>
