<?xml version="1.0" encoding="utf-8"?>
<!--
  This XAML file defines the visual appearance of the Classworks widget.
  Avalonia uses a XAML dialect very similar to WPF/UWP.  The view binds to
  properties on the ClassworksViewModel via the DataContext set in
  ClassworksWidget.BuildContent().
-->
<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:ClassworksPlugin"
             x:Class="ClassworksPlugin.Views.ClassworksWidgetView"
             mc:Ignorable="d">
  <Border Padding="8" CornerRadius="8" Background="#AAFFFFFF">
    <StackPanel>
      <!-- Header -->
      <TextBlock Text="作业列表" FontSize="16" FontWeight="Bold" Margin="0,0,0,8"/>

      <!-- 配置输入字段 -->
      <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,0,0,8">
        <TextBlock Text="命名空间:" VerticalAlignment="Center"/>
        <TextBox Width="100" Text="{Binding NamespaceId, Mode=TwoWay}"/>
        <TextBlock Text="密码:" VerticalAlignment="Center"/>
        <PasswordBox Width="80" Password="{Binding Password, Mode=TwoWay}"/>
        <TextBlock Text="AppId:" VerticalAlignment="Center"/>
        <TextBox Width="140" Text="{Binding AppId, Mode=TwoWay}"/>
        <Button Content="刷新" Click="OnRefreshClick"/>
      </StackPanel>

      <!-- Status / loading indicator -->
      <TextBlock Text="{Binding Status}" FontStyle="Italic" Foreground="Gray" Margin="0,0,0,8"/>

      <!-- Assignment list -->
      <ListBox Items="{Binding Assignments}" ScrollViewer.VerticalScrollBarVisibility="Auto">
        <ListBox.ItemTemplate>
          <DataTemplate DataType="{x:Type local:Assignment}">
            <Border Padding="4" Margin="0,0,0,4" CornerRadius="4" Background="#F0F0F0">
              <StackPanel>
                <TextBlock Text="{Binding Title}" FontWeight="Bold"/>
                <TextBlock Text="{Binding Description}" TextWrapping="Wrap" FontSize="12" Margin="0,2,0,0"/>
                <TextBlock Text="{Binding DueDate, StringFormat=截止日期: {0:yyyy-MM-dd}}" FontSize="11" Foreground="DarkSlateGray"/>
              </StackPanel>
            </Border>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>

      <!-- 新建作业输入行 -->
      <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,8,0,0">
        <TextBox Width="100" Watermark="科目" Text="{Binding NewTitle, Mode=TwoWay}"/>
        <TextBox Width="220" Watermark="内容" Text="{Binding NewDescription, Mode=TwoWay}"/>
        <Button Content="添加" Click="OnAddClick"/>
      </StackPanel>
    </StackPanel>
  </Border>
</UserControl>